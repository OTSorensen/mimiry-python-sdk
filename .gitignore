# Build artifacts (regenerable via `python -m build`)
dist/
build/
*.egg-info/

# Python caches / bytecode
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
.mypy_cache/
.ruff_cache/
.tox/

# Virtual environments
.venv/
venv/
ENV/

# Secrets & credentials — NEVER commit
*.pem
*.key
id_*
*_rsa
*_ed25519
.env
.env.*
*.token

# Internal / scratch — NEVER publish (added 2026-06 after public-repo audit)
development-files/
internal/
private/
scratch/
notes/
drafts/
*-internal.*
*-private.*
*.internal.*
*.private.*
*.draft
*.draft.*
# Doc-leak guards: roadmap / architecture / strategy notes kept out of the public package
**/api-roadmap.md
**/*-roadmap.md
**/internal-*.md

# OS cruft
.DS_Store
Thumbs.db

.build-venv/
